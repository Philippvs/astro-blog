---
import '../styles/global.css';

const person = {
  name: 'Philipp von Spinn',
  role: 'Software Engineer',
  location: 'Austria, Innsbruck',
  phone: '+39 3458431018',
  email: 'philipp.von.spinn@gmail.com',
  birthYear: '1997',
  summary:
    'Software Engineer with a strong focus on Java and Spring Boot. Several years of experience developing cloud-ready backend applications in agile teams. Strong emphasis on stable backend architectures, system integration, and CI/CD pipelines.',
};

const skills = [
  'Java',
  'Spring Boot',
  'Hibernate',
  'SQL',
  'React',
  'Angular',
  'TypeScript',
  'Docker',
  'CI/CD',
  'Cloud',
  'Git',
  'Scrum',
  'Kanban',
];

const experience = [
  {
    role: 'Fullstack Software Engineer',
    company: 'eMundo / Gofore',
    period: '07/2019 - Present',
    points: [
      'Development and optimization of Java and Spring Boot backends to implement customer-specific requirements.',
      'Design and implementation of REST APIs, business logic, and PostgreSQL data models.',
      'Technical responsibility for the integration and synchronization of data flows between internal and external systems.',
      'Setup and operation of CI/CD pipelines, including automated testing and deployments.',
      'Contribution to frontend features using React and Angular.',
    ],
  },
];

const education = [
  {
    degree: "Master's Degree: Software Engineering",
    school: 'University of Innsbruck',
    period: '09/2020 - 10/2024',
  },
  {
    degree: "Bachelor's Degree: Computer Science",
    school: 'University of Innsbruck',
    period: '09/2016 - 07/2020',
  },
  {
    degree: 'High School Diploma (Matura): Electronics and Electrical Engineering',
    school: 'Technological Upper Secondary School, Merano',
    period: '09/2011 - 07/2016',
  },
];

const certifications = [
  {
    title: 'iSAQB: CPSA',
    detail: 'Certified Professional for Software Architecture Foundation Level',
  },
];

const languages = [
  { name: 'German', level: 'Native' },
  { name: 'Italian', level: 'Good working knowledge' },
  { name: 'English', level: 'Very good working knowledge' },
];

const interests = [
  'Self-improvement and personal development',
  'Health and sports',
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{person.name} | CV</title>
    <meta
      name="description"
      content="CV page for Philipp von Spinn with experience, education, certifications, languages, and skills."
    />
  </head>
  <body>
    <main class="page-shell cv-page">
      <a class="back-link" href={`${import.meta.env.BASE_URL}`}>← Back to home</a>

      <section class="cv-layout">
        <aside class="cv-sidebar panel">
          <section class="cv-section">
            <h2>Contact</h2>
            <ul class="contact-list">
              <li>{person.location}</li>
              <li>{person.phone}</li>
              <li><a href={`mailto:${person.email}`}>{person.email}</a></li>
              <li>{person.birthYear}</li>
            </ul>
          </section>

          <section class="cv-section">
            <h2>Profile</h2>
            <p>{person.summary}</p>
          </section>

          <section class="cv-section">
            <h2>Core skills</h2>
            <ul class="skill-list">
              {skills.map((skill) => <li>{skill}</li>)}
            </ul>
          </section>
        </aside>

        <section class="cv-main panel">
          <header class="cv-header">
            <p class="eyebrow">Curriculum Vitae</p>
            <h1>{person.name}</h1>
            <p class="lead">{person.role}</p>
          </header>

          <section class="cv-section">
            <h2>Professional experience</h2>
            {experience.map((job) => (
              <article class="timeline-item">
                <h3>{job.role}: {job.company}</h3>
                <p class="meta">{job.period}</p>
                <ul>
                  {job.points.map((point) => <li>{point}</li>)}
                </ul>
              </article>
            ))}
          </section>

          <section class="cv-section">
            <h2>Education</h2>
            <div class="stack-list">
              {education.map((entry) => (
                <article class="list-item compact">
                  <h3>{entry.degree}</h3>
                  <p>{entry.school}</p>
                  <p class="meta">{entry.period}</p>
                </article>
              ))}
            </div>
          </section>

          <section class="cv-section two-col">
            <div>
              <h2>Certifications</h2>
              {certifications.map((cert) => (
                <article class="mini-block">
                  <h3>{cert.title}</h3>
                  <p>{cert.detail}</p>
                </article>
              ))}
            </div>

            <div>
              <h2>Languages</h2>
              <div class="stack-list small-gap">
                {languages.map((language) => (
                  <article class="mini-block">
                    <h3>{language.name}</h3>
                    <p>{language.level}</p>
                  </article>
                ))}
              </div>
            </div>
          </section>

          <section class="cv-section">
            <h2>Interests</h2>
            <ul>
              {interests.map((interest) => <li>{interest}</li>)}
            </ul>
          </section>
        </section>
      </section>
    </main>
  </body>
</html>


<style>
/* =========================
   PAGE SETUP (A4)
========================= */

.cv-page {
  display: flex;
  justify-content: center;
  padding: 40px 0;
  background: #f4f6f8;
}

/* A4 SHELL */
.page-shell {
  width: 210mm;
  min-height: 297mm;
  background: white;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10px 40px rgba(0,0,0,0.08);
}

/* MAIN CV GRID */
.cv-layout {
  display: grid;
  grid-template-columns: 34% 66%;
  min-height: 100%;
}

/* SIDEBAR */
.cv-sidebar {
  background: #eef3f6;
  padding: 22mm 14mm;
}

/* MAIN AREA */
.cv-main {
  padding: 22mm 16mm;
}

/* =========================
   TYPOGRAPHY
========================= */

h1 {
  font-size: 28px;
  margin: 0;
  letter-spacing: -0.3px;
}

.lead {
  margin-top: 4px;
  font-size: 14px;
  color: #444;
}

h2 {
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  margin-bottom: 12px;
  color: #111;
}

h3 {
  font-size: 14px;
  margin-bottom: 4px;
}

p, li {
  font-size: 12.5px;
  line-height: 1.5;
  color: #222;
}

/* =========================
   SPACING SYSTEM
========================= */

.cv-section + .cv-section {
  margin-top: 18px;
}

/* CONTACT / SKILLS */
.contact-list,
.skill-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.contact-list li,
.skill-list li {
  margin-bottom: 6px;
}

/* Skills bullets */
.skill-list li::before {
  content: "•";
  margin-right: 6px;
  color: #2b6cb0;
}

/* EXPERIENCE */
.timeline-item {
  margin-bottom: 14px;
}

.timeline-item ul {
  margin-top: 6px;
  padding-left: 16px;
}

/* EDUCATION */
.stack-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.meta {
  font-size: 11px;
  color: #666;
}

/* TWO COLUMN BLOCK */
.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* HEADER */
.cv-header {
  margin-bottom: 20px;
}

.eyebrow {
  font-size: 10px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #666;
}

/* =========================
   LINKS / UI CLEANUP
========================= */

.back-link {
  display: none; /* never print / optional hide on screen too */
}

/* =========================
   PRINT OPTIMIZATION
========================= */

@media print {
  body {
    background: white;
  }

  .cv-page {
    padding: 0;
  }

  .page-shell {
    box-shadow: none;
    width: 100%;
    height: auto;
  }

  /* force clean black/white print */
  * {
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* avoid breaking sections badly */
  .cv-section,
  .timeline-item,
  .stack-list {
    break-inside: avoid;
  }

  /* remove unnecessary spacing for print density */
  .cv-sidebar,
  .cv-main {
    padding: 15mm 12mm;
  }
}

/* =========================
   MOBILE (unchanged logic)
========================= */

@media (max-width: 900px) {
  .cv-layout,
  .two-col {
    grid-template-columns: 1fr;
  }

  .page-shell {
    width: 100%;
  }
}
</style>

